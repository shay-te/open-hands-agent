# OpenHands agent application
YOUTRACK_BASE_URL=https://your-company.youtrack.cloud
YOUTRACK_TOKEN=
YOUTRACK_PROJECT=PROJ
YOUTRACK_ASSIGNEE=me
YOUTRACK_REVIEW_STATE_FIELD=State
YOUTRACK_REVIEW_STATE=In Review

BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0
BITBUCKET_TOKEN=
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_REPO_SLUG=your-repo

OPENHANDS_API_KEY=local
OPENHANDS_AGENT_MAX_RETRIES=5

OPENHANDS_AGENT_FAILURE_EMAIL_ENABLED=false
OPENHANDS_AGENT_FAILURE_EMAIL_TEMPLATE_ID=0
OPENHANDS_AGENT_FAILURE_EMAIL_TO=
OPENHANDS_AGENT_FAILURE_EMAIL_SENDER_NAME=OpenHands Agent
OPENHANDS_AGENT_FAILURE_EMAIL_SENDER_EMAIL=noreply@example.com

OPENHANDS_AGENT_COMPLETION_EMAIL_ENABLED=false
OPENHANDS_AGENT_COMPLETION_EMAIL_TEMPLATE_ID=0
OPENHANDS_AGENT_COMPLETION_EMAIL_TO=
OPENHANDS_AGENT_COMPLETION_EMAIL_SENDER_NAME=OpenHands Agent
OPENHANDS_AGENT_COMPLETION_EMAIL_SENDER_EMAIL=noreply@example.com

EMAIL_CORE_LIB_SEND_IN_BLUE_API_KEY=
SLACK_WEBHOOK_URL_ERRORS_EMAIL=

# OpenHands container
OPENHANDS_PORT=3000
OPENHANDS_STATE_DIR=~/.openhands
OPENHANDS_WEB_URL=http://localhost:3000
OPENHANDS_RUNTIME=docker
OPENHANDS_AGENT_SERVER_IMAGE_REPOSITORY=
OPENHANDS_AGENT_SERVER_IMAGE_TAG=

# OpenHands LLM configuration
# Example OpenAI model: openai/gpt-4o
# Example OpenHands Cloud model: openhands/claude-sonnet-4-20250514
OPENHANDS_LLM_MODEL=
OPENHANDS_LLM_API_KEY=
OPENHANDS_LLM_BASE_URL=
OPENHANDS_LLM_API_VERSION=
OPENHANDS_LLM_NUM_RETRIES=
OPENHANDS_LLM_TIMEOUT=
OPENHANDS_LLM_DISABLE_VISION=
OPENHANDS_LLM_DROP_PARAMS=
OPENHANDS_LLM_CACHING_PROMPT=

# Optional AWS credentials for Bedrock-backed LLM setups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=
AWS_BEARER_TOKEN_BEDROCK=
