# Kato agent application
KATO_ISSUE_PLATFORM=youtrack
# Selects which agent runs the implementation/testing/review work.
# Supported values: openhands (default) | claude
# - openhands: drives the OpenHands HTTP server (uses the OPENHANDS_* settings below).
# - claude:    drives Anthropic's Claude Code CLI locally (`claude -p`); uses the
#              KATO_CLAUDE_* settings further down. The OPENHANDS_* block can stay
#              empty when this is set to `claude`.
KATO_AGENT_BACKEND=openhands
KATO_LOG_LEVEL=warning
KATO_WORKFLOW_LOG_LEVEL=info
KATO_EXTERNAL_API_MAX_RETRIES=5
# Per-task workspace folders. Each task gets a subdirectory named after
# its ticket id (e.g. PROJ-12) containing fresh clones of every repo it
# touches. Empty = ~/.kato/workspaces. The planning UI's tab list reads
# from this root: one folder = one tab.
KATO_WORKSPACES_ROOT=
# How many tasks the orchestrator processes in parallel. The main scan
# thread still validates and reserves slots one-at-a-time; only the
# heavy execute / test / publish work runs concurrently.
# Default 2 — runs up to two tasks at a time. Bump higher (3-5) when
# you have generous LLM rate limits and want faster throughput on a
# busy assignee. Set to 1 for the strictly-sequential legacy behavior
# (useful when downstream services are rate-limited per-IP).
KATO_MAX_PARALLEL_TASKS=2
# Comma-separated folder names to exclude from repository auto-discovery.
KATO_IGNORED_REPOSITORY_FOLDERS=
# Comma-separated repository ids that kato must NEVER touch. Entries are
# matched case-insensitively against ``Repository.id`` (e.g. "secrets-vault,
# customer-bespoke"). Filtered repos are dropped from the inventory at boot
# with a WARNING log so a missing repo does not look like a config bug.
# Use this for secrets-vault repos, regulated-data repos, or any clone you
# refuse to let the agent see — boot-time refusal fires even if the
# inventory config is otherwise broken.
KATO_REPOSITORY_DENYLIST=
# Generated from the repository source fingerprint helper.
KATO_SOURCE_FINGERPRINT=
KATO_FAILURE_EMAIL_ENABLED=false
KATO_FAILURE_EMAIL_TEMPLATE_ID=0
KATO_FAILURE_EMAIL_TO=
KATO_FAILURE_EMAIL_SENDER_NAME=Kato
KATO_FAILURE_EMAIL_SENDER_EMAIL=noreply@example.com
KATO_COMPLETION_EMAIL_ENABLED=false
KATO_COMPLETION_EMAIL_TEMPLATE_ID=0
KATO_COMPLETION_EMAIL_TO=
KATO_COMPLETION_EMAIL_SENDER_NAME=Kato
KATO_COMPLETION_EMAIL_SENDER_EMAIL=noreply@example.com
KATO_AGENT_SERVER_IMAGE_REPOSITORY=
KATO_AGENT_SERVER_IMAGE_TAG=
# Host port that publishes the Kato planning UI webserver (Flask) when running
# under docker compose. Inside the container the webserver always binds 0.0.0.0.
KATO_WEBSERVER_PORT=5050
# Claude Code CLI backend (used only when KATO_AGENT_BACKEND=claude).
# Install Claude Code: https://docs.claude.com/en/docs/claude-code/setup
#
# Auth — pick ONE:
#   (A) Max/Pro plan, recommended for Docker: run `claude setup-token` on the
#       host, copy the printed token into CLAUDE_CODE_OAUTH_TOKEN below. This
#       bills your subscription, not the API balance, and survives into the
#       container (the macOS Keychain does not).
#   (B) Pay-per-token API: set ANTHROPIC_API_KEY. Required only if you don't
#       have a Max/Pro plan, or for headless servers without browser access.
#   (C) Local interactive (only `make run`, not Docker): run `claude login`
#       once on the host. The Kato process inherits your Keychain credentials.
# Path to the `claude` binary. Plain `claude` works when it is on PATH.
KATO_CLAUDE_BINARY=claude
# Optional model override. Leave empty to use Claude Code's configured default.
# Example: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
KATO_CLAUDE_MODEL=
# Optional cap on agent turns per task; empty means no cap.
KATO_CLAUDE_MAX_TURNS=
# Reasoning depth knob passed via `--effort`.
# Accepted: low | medium | high | xhigh | max. Empty = Claude's default.
# Higher levels burn more tokens / time but think harder before acting.
KATO_CLAUDE_EFFORT=
# Optional comma-separated allow/deny tool lists passed to `--allowedTools` / `--disallowedTools`.
# When KATO_CLAUDE_BYPASS_PERMISSIONS=false, an empty allow list is replaced at
# runtime with a safe default (Edit,Write,Read,Bash,Glob,Grep) so the headless
# `claude -p` agent does not stall asking for permission mid-task.
KATO_CLAUDE_ALLOWED_TOOLS=
KATO_CLAUDE_DISALLOWED_TOOLS=
# Opt-in to wrap every Claude spawn in the hardened Docker sandbox
# (workspace bind-mount only, default-DROP egress firewall, capability
# drop, read-only rootfs, audit log). Independent of bypass mode —
# docker without bypass still works (per-tool prompts continue via the
# planning UI). Required for ``KATO_CLAUDE_BYPASS_PERMISSIONS=true``
# and ``KATO_CLAUDE_ALLOWED_READ_ONLY_TOOLS=true`` — both refuse to
# start without docker. Default false. See BYPASS_PROTECTIONS.md.
KATO_CLAUDE_DOCKER=false

# Pre-approve a hardcoded read-only Bash allowlist (grep / cat / ls /
# find / etc.) so the operator isn't prompted mid-task for safe
# inspection commands. Requires ``KATO_CLAUDE_DOCKER=true`` — kato
# refuses at startup otherwise, because without the sandbox even
# ``grep`` runs on the host and can read SSH keys or any file the
# operator can read. Default false.
KATO_CLAUDE_ALLOWED_READ_ONLY_TOOLS=false

# Opt-in to `--permission-mode bypassPermissions` (a.k.a. --dangerously-skip-permissionsBYPASS_PROTECTIONS.md).
# Default false → uses the safer `acceptEdits` mode plus the pre-approved tools list.
#
# When true, the agent runs every tool (Bash, Edit, Write, …) without asking,
# inside the hardened Docker sandbox (see BYPASS_PROTECTIONS.md).
# Kato refuses to start with this flag set in any of the following cases:
#   - the process runs as root (no exception),
#   - ``KATO_CLAUDE_DOCKER=true`` is not set (the sandbox is the
#     structural boundary that makes "no prompts" survivable),
#   - a non-interactive environment (CI / Docker / cron / systemd) — kato
#     can only get acknowledgement from a TTY, so unattended runs are
#     refused outright,
#   - an interactive shell where the operator answers "no" to either of
#     the two confirmation prompts at startup.
# When true, kato also writes an unmissable stderr banner and a planning-UI
# banner so the bypass state is visible to the operator. See SECURITY.md.
KATO_CLAUDE_BYPASS_PERMISSIONS=false

# ----- pre-execution security scanner -----
# Runs before each task, scans the per-task workspace clone for
# committed secrets / vulnerable deps / dangerous code patterns,
# and blocks the task on CRITICAL findings by default. HIGH+ findings
# surface in the ticket comment as warnings but don't refuse the
# task — operators who want a stricter gate can tighten
# ``block_on_severity`` in conf/kato_core_lib.yaml. See
# plans/02-security-scanner-service.md and
# kato_core_lib/data_layers/service/security_scanner_runners/.
#
# Default ON because committed-secret incidents are the most
# common breach pattern in small-team codebases. Set to false to
# disable entirely (NOT recommended for any team that ships to
# production).
KATO_SECURITY_SCANNER_ENABLED=true
# Per-runner toggles. If a runner's tool isn't installed, kato
# logs a warning and skips it — disabling here just silences
# the warning.
KATO_SECURITY_RUNNER_ENV_FILE=true
KATO_SECURITY_RUNNER_DETECT_SECRETS=true
KATO_SECURITY_RUNNER_BANDIT=true
KATO_SECURITY_RUNNER_SAFETY=true
# npm-audit is OFF by default — for any non-trivial JS project it
# produces dozens of transitive-dep CVE findings that almost never
# reflect exploitable issues in the operator's own code. Flip to
# ``true`` if you want kato to surface them (still won't refuse the
# task on CRITICAL-only default).
KATO_SECURITY_RUNNER_NPM_AUDIT=false
# Per-runner timeout in seconds. A stuck scanner doesn't block
# the operator forever — at the timeout, the task proceeds with
# a warning instead of being blocked.
KATO_SECURITY_TIMEOUT_SECRETS=60
KATO_SECURITY_TIMEOUT_DEPENDENCIES=120
KATO_SECURITY_TIMEOUT_CODE_PATTERNS=120

# ----- restricted execution protocol -----
# REP gates the *first* agent run against any repository: until the
# operator has explicitly approved a repo id (via
# `./kato approve-repo <id> --remote <git-url>`), kato refuses to
# clone or run the agent against it. REP is always on — there is
# no off switch.
#
# Override the approval sidecar location. Empty = ~/.kato/approved-repositories.json.
# Used mostly by tests; production deployments should leave blank.
KATO_APPROVED_REPOSITORIES_PATH=
# Identity recorded as ``approved_by`` on each approval row. Empty
# falls back to $USER / $USERNAME. Audit metadata only — no auth
# decision hangs on this value.
KATO_OPERATOR_EMAIL=

# Per-task subprocess timeout for the Claude CLI in seconds.
KATO_CLAUDE_TIMEOUT_SECONDS=1800
# Run a startup smoke test prompt to verify model access. Off by default to avoid spend.
KATO_CLAUDE_MODEL_SMOKE_TEST_ENABLED=false

# Optional path to a project-architecture markdown file. When set, kato
# appends the file's contents to Claude's system prompt on every spawn
# (autonomous, planning, and chat respawn) so existing and new sessions
# share the same project context. The file is re-read on each spawn, so
# editing it takes effect on the next turn without restarting kato.
KATO_ARCHITECTURE_DOC_PATH=

# Retries for the publish step (per-repo PR creation + the move-to-review
# transition on YouTrack/Jira/etc.). Implementation work is never re-run
# on retry. Defaults to 2 retries (up to 3 attempts) with exponential
# backoff so transient git push / Bitbucket / YouTrack errors don't
# kill an otherwise-successful task.
KATO_TASK_PUBLISH_MAX_RETRIES=2

# How long a workspace in `review` state survives before the cleanup loop
# deletes it, even if the ticket is still in the review bucket. Default
# 3600s = 1 hour. After this window, the local clone is removed; kato
# re-clones on demand if a review comment fires for an already-cleaned
# task. Set to 0 to disable TTL-based cleanup (workspace persists for the
# full review bucket lifetime, which is the legacy behavior).
KATO_WORKSPACE_REVIEW_TTL_SECONDS=3600

YOUTRACK_API_BASE_URL=https://your-company.youtrack.cloud
YOUTRACK_API_TOKEN=
YOUTRACK_PROJECT=PROJ
YOUTRACK_ASSIGNEE=your-youtrack-login
YOUTRACK_PROGRESS_STATE_FIELD=State
YOUTRACK_PROGRESS_STATE=In Progress
YOUTRACK_REVIEW_STATE_FIELD=State
YOUTRACK_REVIEW_STATE=To Verify
YOUTRACK_ISSUE_STATES=Todo,Open

JIRA_API_BASE_URL=
JIRA_API_TOKEN=
JIRA_EMAIL=
JIRA_PROJECT=
JIRA_ASSIGNEE=
JIRA_PROGRESS_STATE_FIELD=status
JIRA_PROGRESS_STATE=In Progress
JIRA_REVIEW_STATE_FIELD=status
JIRA_REVIEW_STATE=In Review
JIRA_ISSUE_STATES=To Do,Open

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_ASSIGNEE=
GITHUB_PROGRESS_STATE_FIELD=labels
GITHUB_PROGRESS_STATE=In Progress
GITHUB_REVIEW_STATE_FIELD=labels
GITHUB_REVIEW_STATE=In Review
GITHUB_ISSUE_STATES=open
# Also used for GitHub pull request API access when discovered repositories live on GitHub.

GITLAB_API_BASE_URL=https://gitlab.com/api/v4
GITLAB_API_TOKEN=
GITLAB_PROJECT=
GITLAB_ASSIGNEE=
GITLAB_PROGRESS_STATE_FIELD=labels
GITLAB_PROGRESS_STATE=In Progress
GITLAB_REVIEW_STATE_FIELD=labels
GITLAB_REVIEW_STATE=In Review
GITLAB_ISSUE_STATES=opened
# Also used for GitLab merge request API access when discovered repositories live on GitLab.

BITBUCKET_API_BASE_URL=https://api.bitbucket.org/2.0
BITBUCKET_API_TOKEN=
BITBUCKET_USERNAME=
# BITBUCKET_USERNAME is used for git push auth.
BITBUCKET_API_EMAIL=
# BITBUCKET_API_EMAIL is used for Bitbucket REST API auth.
BITBUCKET_WORKSPACE=
BITBUCKET_REPO_SLUG=
BITBUCKET_ASSIGNEE=
BITBUCKET_PROGRESS_STATE_FIELD=state
BITBUCKET_PROGRESS_STATE=open
BITBUCKET_REVIEW_STATE_FIELD=state
BITBUCKET_REVIEW_STATE=resolved
BITBUCKET_ISSUE_STATES=new,open
# Also used for Bitbucket pull request API access when discovered repositories live on Bitbucket.

# Root folder containing checked-out repositories. The agent scans this folder
# and matches repository or folder names from the task description.
# Pull request provider examples:
# Bitbucket: https://api.bitbucket.org/2.0
# GitHub: https://api.github.com
# GitLab: https://gitlab.com/api/v4
REPOSITORY_ROOT_PATH=.
MOUNT_DOCKER_DATA_ROOT=./mount_docker_data
OPENHANDS_BASE_URL=http://localhost:3000
OPENHANDS_API_KEY=local
OPENHANDS_SKIP_TESTING=false
OPENHANDS_TESTING_CONTAINER_ENABLED=false
OPENHANDS_TESTING_BASE_URL=http://localhost:3001
OPENHANDS_TESTING_PORT=3001
# Defaults used by the `openhands` Docker Compose service.
OPENHANDS_CONTAINER_LOG_ALL_EVENTS=true
EMAIL_CORE_LIB_SEND_IN_BLUE_API_KEY=
SLACK_WEBHOOK_URL_ERRORS_EMAIL=

# OpenHands container
OPENHANDS_PORT=3000
OPENHANDS_PULL_POLICY=missing
OPENHANDS_LOG_LEVEL=error
# Set a stable random secret so OpenHands can persist secrets safely across restarts.
OH_SECRET_KEY=
# Host path for OpenHands state storage. Prefer an absolute path when overriding.
OPENHANDS_STATE_DIR=~/.openhands
OPENHANDS_WEB_URL=http://localhost:3000
OPENHANDS_RUNTIME=docker
# Host SSH agent socket path for SSH git remotes such as git@bitbucket.org:...
# Docker Desktop on macOS exposes this path by default.
OPENHANDS_SSH_AUTH_SOCK_HOST_PATH=/run/host-services/ssh-auth.sock

# OpenHands LLM configuration
# Example OpenAI model: openai/gpt-4o
# Example OpenHands Cloud model: openhands/claude-sonnet-4-20250514
OPENHANDS_LLM_MODEL=
OPENHANDS_LLM_API_KEY=
OPENHANDS_LLM_BASE_URL=
OPENHANDS_MODEL_SMOKE_TEST_ENABLED=true
OPENHANDS_TESTING_LLM_MODEL=
OPENHANDS_TESTING_LLM_API_KEY=
OPENHANDS_TESTING_LLM_BASE_URL=
OPENHANDS_LLM_API_VERSION=
OPENHANDS_LLM_NUM_RETRIES=
OPENHANDS_LLM_TIMEOUT=
OPENHANDS_POLL_INTERVAL_SECONDS=2.0
OPENHANDS_MAX_POLL_ATTEMPTS=900
# Delay before the first scan tick after kato boots. 5 seconds is enough
# for the planning UI to come up before the first task is picked. Set to
# 0 if you want kato to dispatch immediately (e.g. CI).
OPENHANDS_TASK_SCAN_STARTUP_DELAY_SECONDS=5
# 0 disables the autonomous scan loop entirely — every task pickup
# and review-comment check has to be triggered manually from the UI
# ("Scan now" / per-task "Sync" buttons) or via POST /api/scan/trigger.
# Set >0 (e.g. 60) to opt into periodic polling. Disabling is the
# default to avoid hammering provider APIs (Bitbucket / GitHub /
# GitLab) with parallel PR-lookups on every tick.
OPENHANDS_TASK_SCAN_INTERVAL_SECONDS=0
OPENHANDS_LLM_DISABLE_VISION=
OPENHANDS_LLM_DROP_PARAMS=
OPENHANDS_LLM_CACHING_PROMPT=

# Optional AWS credentials for Bedrock-backed LLM setups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=
AWS_SESSION_TOKEN=
AWS_BEARER_TOKEN_BEDROCK=
