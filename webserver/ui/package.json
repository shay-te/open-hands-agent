{
  "name": "kato-planning-ui",
  "version": "0.1.0",
  "private": true,
  "description": "React-driven right-side pane (Files + Changes) for the Kato planning UI.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:css",
    "build:css": "sass src/styles/app.scss ../static/css/app.css --no-source-map --no-charset --style=expanded",
    "test": "npm run test:node && npm run test:vitest",
    "test:node": "node --test src/*.test.js src/utils/*.test.js src/hooks/*.test.js src/components/*.test.js src/stores/*.test.js",
    "test:vitest": "vitest run",
    "dedup": "npx --yes jscpd src"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@monaco-editor/react": "^4.7.0",
    "react": "^18.3.1",
    "react-arborist": "^3.4.0",
    "react-diff-view": "^3.2.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "refractor": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "unidiff": "^1.0.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "sass": "^1.100.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.6"
  }
}
